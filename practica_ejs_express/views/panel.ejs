<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Panel de Usuario</title>
  </head>
  <body>
   <% let saludo;
    if(user.genero ==="m"){
      saludo = "Bienvenido";
    }else if(user.genero ==="f"){
      saludo = "Bienvenida";
    }else {
      saludo = " Bienvenide"
    }
     %>
  <h1 style="text-transform: capitalize;">  <%= saludo + " "+  user.nombre %>  </h1>
  <p> <%= user.is_admin ? "Eres administrador" : "No eres administrador" %> </p>
 </body>

</html>
